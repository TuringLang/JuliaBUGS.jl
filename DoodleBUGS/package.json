{
  "name": "doodlebugs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p typecheck \"build-only {@}\" --",
    "preview": "vite preview --host",
    "build-only": "vite build",
    "build:lib": "run-p typecheck \"build-lib-only {@}\" --",
    "build-lib-only": "vite build --config vite.lib.config.ts",
    "build:all": "npm run build:lib && npm run build",
    "typecheck": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.ts,.mts,.tsx",
    "lint:fix": "eslint . --ext .vue,.ts,.mts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,mts,tsx,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,tsx,vue,json,md}\"",
    "validate": "npm run typecheck && npm run lint && npm run format:check"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "@types/cytoscape": "^3.31.0",
    "codemirror": "^6.0.2",
    "cytoscape": "^3.34.0",
    "cytoscape-cola": "^2.5.1",
    "cytoscape-dagre": "^4.0.0",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-klay": "^3.1.4",
    "cytoscape-svg": "^0.4.0",
    "cytoscape-undo-redo": "^1.3.3",
    "lodash": "^4.17.23",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/codemirror": "^5.60.17",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vue-tsc": "^3.3.6"
  }
}
