{
  "name": "doodlebugs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p typecheck \"build-only {@}\" --",
    "preview": "vite preview --host",
    "build-only": "vite build",
    "typecheck": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.ts,.mts,.tsx",
    "lint:fix": "eslint . --ext .vue,.ts,.mts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,mts,tsx,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,tsx,vue,json,md}\"",
    "validate": "npm run typecheck && npm run lint && npm run format:check"
  },
  "dependencies": {
    "doodleppl": "^0.2.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.14.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "~10.0.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.5.2",
    "typescript": "~5.8.0",
    "vite": "^6.4.2",
    "vue-tsc": "^2.2.8"
  }
}
