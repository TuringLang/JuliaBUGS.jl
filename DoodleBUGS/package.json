{
  "name": "doodlebugs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md,html}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,html}\"",
    "validate": "npm run typecheck && npm run format:check"
  },
  "dependencies": {
    "doodleppl": "^0.4.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prettier": "^3.5.2",
    "typescript": "~5.8.0",
    "vite": "^6.4.2"
  }
}
